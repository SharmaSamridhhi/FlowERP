# Copy this file to `.env` and fill in real (local-dev, non-secret) values.
# `.env` is gitignored — never commit real secrets. See
# specs/FLO-018-env-config-secrets.md and src/config/env.ts for validation.

# Port the server listens on. Optional — defaults to 4000.
PORT=4000

# development | test | production. Optional — defaults to development.
NODE_ENV=development

# PostgreSQL connection string used by Prisma and the app itself.
# Required — must be set before `npm install` (postinstall runs
# `prisma generate`, which needs a syntactically valid value).
DATABASE_URL="postgresql://<user>@localhost:5432/flowerp_dev?schema=public"

# Only needed locally to run the backend test suite (see backend/TESTING.md).
# A separate database from DATABASE_URL — tests never touch the dev database.
TEST_DATABASE_URL="postgresql://<user>@localhost:5432/flowerp_test?schema=public"
JWT_SECRET="replace-with-a-long-random-local-dev-secret"
JWT_EXPIRES_IN=8h
CORS_ORIGIN=http://localhost:5173

# Password used for all demo users created by `prisma/seed.ts`. Optional
SEED_USER_PASSWORD=FlowERP123!
