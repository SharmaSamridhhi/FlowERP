{
  "name": "flowerp",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "flowerp",
      "version": "0.0.0",
      "workspaces": [
        "backend",
        "frontend",
        "packages/*"
      ],
      "engines": {
        "node": ">=20.19.0"
      }
    },
    "backend": {
      "name": "@flowerp/backend",
      "version": "0.0.0"
    },
    "frontend": {
      "name": "@flowerp/frontend",
      "version": "0.0.0"
    },
    "node_modules/@flowerp/backend": {
      "resolved": "backend",
      "link": true
    },
    "node_modules/@flowerp/frontend": {
      "resolved": "frontend",
      "link": true
    },
    "node_modules/@flowerp/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@flowerp/shared",
      "version": "0.0.0"
    }
  }
}
