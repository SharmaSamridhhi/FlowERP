{
  "name": "flowerp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Mini ERP + CRM Operations Portal for a wholesale/distribution company.",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "backend",
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky && npm run build -w packages/shared",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "build": "npm run build -w packages/shared && npm run build -w backend && npm run build -w frontend",
    "dev": "npm run build -w packages/shared && concurrently -n shared,backend,frontend -c blue,green,magenta \"npm run dev -w packages/shared\" \"npm run dev -w backend\" \"npm run dev -w frontend\""
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.6",
    "typescript-eslint": "^8.65.0"
  }
}
